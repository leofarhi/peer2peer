generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// L'Utilisateur
model User {
  id            String   @id @default(uuid())
  intraId       Int      @unique
  email         String   @unique
  login         String   @unique
  
  name          String
  birthDate     DateTime 
  
  gender        String   @default("MALE")
  campus        String   @default("Paris")
  bio           String?
  intraPhoto    String
  customPhotos  String[]

  intent        String   @default("LTS")
  genderPref    String   @default("ALL")
  ageMin        Int      @default(18)
  ageMax        Int      @default(30)
  
  isOnboarded   Boolean  @default(false)
  
  // --- NOUVEAUX CHAMPS ---
  dailyQuota    Int      @default(30) // Quota de swipes restants
  lastActive    DateTime @default(now()) // Pour savoir quand reset le quota/bonus
  visibilityScore Float  @default(1.0) // Score de visibilité (0.0 à 2.0)
  // -----------------------

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sentLikes     Like[]   @relation("Sender")
  receivedLikes Like[]   @relation("Receiver")
  
  matches1      Match[]  @relation("User1")
  matches2      Match[]  @relation("User2")
  
  messages      Message[] 
  
  blocks        Block[]  @relation("Blocker")
  blockedBy     Block[]  @relation("Blocked")
  reports       Report[] @relation("Reporter")
  reportedBy    Report[] @relation("Reported")

  isAdmin       Boolean @default(false)
  isBanned      Boolean  @default(false)

  contactMessages ContactMessage[]
}

// Un Like
model Like {
  id        String   @id @default(uuid())
  fromId    String
  toId      String
  type      String   @default("LIKE")
  createdAt DateTime @default(now())

  from      User     @relation("Sender", fields: [fromId], references: [id], onDelete: Cascade)
  to        User     @relation("Receiver", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
}

// Un Match
model Match {
  id        String    @id @default(uuid())
  user1Id   String
  user2Id   String
  createdAt DateTime  @default(now())

  user1Seen Boolean   @default(false)
  user2Seen Boolean   @default(false)
  
  user1     User      @relation("User1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User      @relation("User2", fields: [user2Id], references: [id], onDelete: Cascade)
  
  messages  Message[]

  @@unique([user1Id, user2Id])
}

// Les Messages
model Message {
  id        String   @id @default(uuid())
  content   String
  senderId  String
  matchId   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  match     Match?   @relation(fields: [matchId], references: [id], onDelete: SetNull)
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Report {
  id        String   @id @default(uuid())
  reporterId String
  reportedId String
  reason    String
  createdAt DateTime @default(now())

  processed Boolean  @default(false)

  reporter  User     @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported  User     @relation("Reported", fields: [reportedId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(uuid())
  email     String
  message   String
  userId    String?  // Optionnel : lié seulement si connecté
  createdAt DateTime @default(now())

  processed Boolean  @default(false)

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}